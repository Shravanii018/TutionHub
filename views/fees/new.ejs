<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center">
    <div class="col-md-6 col-11">
        <div class="page-header">
            <div>
                <h2 class="page-title">Add Fee Record</h2>
                <p class="page-subtitle">Log a new fee entry</p>
            </div>
        </div>

        <div class="form-card">
            <form action="/fees" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="student" class="form-label">Student</label>
                    <select name="fee[student]" id="student" class="form-select" required>
                        <option value="">-- Select Student --</option>
                        <% for(let student of allStudents) { %>
                        <option value="<%= student._id %>"><%= student.fullName %></option>
                        <% } %>
                    </select>
                    <div class="invalid-feedback">Please select a student</div>
                </div>
                <div class="mb-3">
                    <label for="month" class="form-label">Month</label>
                    <input name="fee[month]" id="month" type="text" class="form-control" placeholder="e.g. July 2026" required>
                    <div class="invalid-feedback">Please enter the month</div>
                </div>
                <div class="mb-3">
                    <label for="amount" class="form-label">Amount (&#8377;)</label>
                    <input name="fee[amount]" id="amount" type="number" class="form-control" placeholder="e.g. 2000" required>
                    <div class="invalid-feedback">Please enter a valid amount</div>
                </div>
                <div class="mb-4">
                    <label for="remark" class="form-label">Remark <span class="text-muted fw-normal">(optional)</span></label>
                    <input name="fee[remark]" id="remark" type="text" class="form-control" placeholder="e.g. Concession applied">
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary">
                        <i class="fa-solid fa-plus"></i> Add Record
                    </button>
                    <a href="/fees" class="btn btn-outline-primary">Cancel</a>
                </div>
            </form>
        </div>
        <br>
        <a href="/fees" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to fees</a>
    </div>
</div>
