<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center">
    <div class="col-md-6 col-11">
        <div class="page-header">
            <div>
                <h2 class="page-title">Edit Student</h2>
                <p class="page-subtitle">Update <%= student.fullName %>'s details</p>
            </div>
        </div>

        <div class="form-card">
            <form action="/students/<%= student._id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="fullName" class="form-label">Full Name</label>
                    <input name="student[fullName]" id="fullName" type="text" value="<%= student.fullName %>" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input name="student[email]" id="email" type="email" value="<%= student.email %>" class="form-control" required>
                </div>
                <div class="mb-4">
                    <label for="phone" class="form-label">Phone</label>
                    <input name="student[phone]" id="phone" type="text" value="<%= student.phone %>" class="form-control">
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                    <a href="/students/<%= student._id %>" class="btn btn-outline-primary">Cancel</a>
                </div>
            </form>
        </div>
        <br>
        <a href="/students/<%= student._id %>" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to student</a>
    </div>
</div>
