<% layout("/layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h2 class="page-title">Notes & PDFs</h2>
        <p class="page-subtitle">Study materials uploaded by your teacher</p>
    </div>
    <% if(currUser.role === "teacher") { %>
    <a href="/content/new" class="btn btn-primary">
        <i class="fa-solid fa-upload"></i> Upload
    </a>
    <% } %>
</div>

<% if(allNotes.length === 0) { %>
<div class="empty-state">
    <i class="fa-solid fa-book-open"></i>
    <p>No content uploaded yet.</p>
    <% if(currUser.role === "teacher") { %>
    <a href="/content/new" class="btn btn-primary">Upload First File</a>
    <% } %>
</div>
<% } else { %>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
    <% for(let note of allNotes) { %>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-start gap-3">
                    <div style="width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
                        background:<%= note.type === 'pdf' ? '#fee2e2' : note.type === 'assignment' ? '#fef3c7' : '#ede9fe' %>">
                        <i class="fa-solid <%= note.type === 'pdf' ? 'fa-file-pdf' : note.type === 'assignment' ? 'fa-pen-to-square' : 'fa-file-lines' %>"
                           style="color:<%= note.type === 'pdf' ? '#dc2626' : note.type === 'assignment' ? '#d97706' : '#7c3aed' %>"></i>
                    </div>
                    <div>
                        <h6 style="font-weight:700;margin-bottom:0.25rem;"><%= note.title %></h6>
                        <p style="color:#6b7280;font-size:0.8rem;margin:0;"><%= note.subject %></p>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="content-type-badge <%= note.type === 'pdf' ? 'type-pdf' : note.type === 'assignment' ? 'type-assignment' : 'type-note' %>">
                        <%= note.type %>
                    </span>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a href="/content/<%= note._id %>" class="btn btn-outline-primary btn-sm">View</a>
                <% if(currUser.role === "teacher") { %>
                <div class="d-flex gap-1">
                    <form method="POST" action="/flashcards/generate/<%= note._id %>">
                        <button class="btn btn-primary btn-sm" title="Generate Flashcards">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </button>
                    </form>
                    <form method="POST" action="/content/<%= note._id %>?_method=DELETE">
                        <button class="btn btn-danger btn-sm">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                </div>
                <% } %>
            </div>
        </div>
    </div>
    <% } %>
</div>
<% } %>
